  "source": "// SPDX-License-Identifier: MIT \npragma solidity ^0.8.19;\n\ncontract ContratoPayable{\n    \n    address public endereco;\n\n    constructor(){\n        endereco = msg.sender;\n    }\n\n    function recebeDineiro() public payable{\n\n        payable(endereco).transfer(msg.value);\n        endereco = msg.sender;\n    }\n}",
